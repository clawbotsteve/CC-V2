  aspect_ratio - AspectRatioEnum "21:9", "16:9", "4:3", "3:2", "1:1", "2:3", "3:4", "9:16", "9:21"
  seed - integer
  sync_mode - boolean

  output::
    images - list<Image>
    seed - integer

      Image
        url - string
