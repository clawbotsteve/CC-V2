# Hoist libsodium packages to fix ESM module resolution issues with pnpm
# This ensures libsodium-wrappers can properly find libsodium modules
public-hoist-pattern[]=*libsodium*

# Enable shamefully-hoist for broader compatibility
shamefully-hoist=true

# Ensure libsodium is available as a peer dependency for libsodium-wrappers
# This helps with ESM module resolution in production
packageExtensions[libsodium-wrappers@*].peerDependencies.libsodium=*
